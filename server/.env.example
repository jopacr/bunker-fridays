# ---- Bunker Fridays server configuration ----
# Every integration below degrades gracefully: if a key is missing the feature
# turns off and the boot log says so, rather than crashing. Copy to .env for
# local use, or set these in your Railway service variables.

# Core
PORT=8080
DATABASE_URL=postgres://bunker:bunker@127.0.0.1:5432/bunker
BASE_URL=http://localhost:8080
# Set true behind HTTPS (Railway) so session cookies are marked Secure.
COOKIE_SECURE=false
# Run migrations automatically on boot (handy on Railway).
MIGRATE_ON_BOOT=false

# Chatbot (server-side Anthropic call; the key never reaches the browser)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Email. Booking drafts are NEVER auto-sent; this powers the explicit
# "Send email" button on a draft, plus account verification / reset emails.
RESEND_API_KEY=
FROM_EMAIL=The Bunker <bookings@bunkerstratford.com>
INFO_EMAIL=info@bunkerstratford.com

# Cloudflare Turnstile (spam protection on the public request form)
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=

# Cloudflare R2 (full-resolution promo photo uploads via presigned PUT)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bunker-photos
R2_PUBLIC_BASE=https://photos.bunkerstratford.com

# Web Push (open-date pings to artists' phones). Generate a VAPID keypair with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@bunkerstratford.com

# Wix Automations webhook shared secret (performer-inquiry bridge).
# Set the same value in the Wix Automation's webhook header x-wix-secret.
WIX_WEBHOOK_SECRET=

# First admin account (used by `npm run seed:admin` when args are omitted)
ADMIN_EMAIL=
ADMIN_PASSWORD=
